NODE_ENV=development

# 42 official REST API
FORTYTWO_REST_BASE=https://rest.ft.42.space

# BNB Chain RPC. Required for later quote/execution phases.
BSC_HTTP_RPC=
BSC_WS_RPC=

# Optional. Enables BscScan transaction/status checks in protocol verification.
BSCSCAN_API_KEY=

# Wallet secrets. Never commit real values.
WALLET_ADDRESS=
PRIVATE_KEY=

# Trading is disabled unless explicitly true.
LIVE_TRADING=false
MAX_TRADE_USDT=5
DAILY_MAX_USDT=30
MAX_OPEN_POSITIONS=3
MAX_SLIPPAGE_BPS=1000
MAX_GAS_GWEI=5
KILL_SWITCH=true
LIVE_TRADING_CONFIRMATION=
INTEGRATOR_ADDRESS=
INTEGRATOR_FEE_BPS=0
PROTOCOL_REPORT_JSON_PATH=./data/protocol-verification-latest.json
JOURNAL_FILE=./data/journal.json

# Strategy/risk defaults
REQUIRE_REAL_MINTS=true
HOT_MARKET_MIN_SCORE=70
MARKET_LOOKBACK_LIMIT=50
POLL_INTERVAL_MS=10000

# Local state
STATE_FILE=./data/state.json

# Apps
API_HOST=0.0.0.0
API_PORT=4210
API_AUTH_TOKEN=
CORS_ORIGIN=
