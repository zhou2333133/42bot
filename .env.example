NODE_ENV=development

# 42space 官方 REST 接口
FORTYTWO_REST_BASE=https://rest.ft.42.space

# BNB 链接口。报价和执行前检查会用到。
BSC_HTTP_RPC=
BSC_WS_RPC=

# 可选。协议核验时用于检查 BscScan 交易和状态。
BSCSCAN_API_KEY=

# 钱包配置。不要提交真实值。
WALLET_ADDRESS=
PRIVATE_KEY=

# 交易默认关闭，必须显式开启。
LIVE_TRADING=false
MAX_TRADE_USDT=5
DAILY_MAX_USDT=30
MAX_OPEN_POSITIONS=3
MAX_SLIPPAGE_BPS=1000
MAX_GAS_GWEI=5
KILL_SWITCH=true
LIVE_TRADING_CONFIRMATION=
INTEGRATOR_ADDRESS=
INTEGRATOR_FEE_BPS=0
PROTOCOL_REPORT_JSON_PATH=./data/protocol-verification-latest.json
SETTINGS_FILE=./data/settings.json
RUNTIME_LOG_FILE=./data/runtime-log.json
JOURNAL_FILE=./data/journal.json

# 策略和风控默认值
REQUIRE_REAL_MINTS=true
HOT_MARKET_MIN_SCORE=70
MARKET_LOOKBACK_LIMIT=50
POLL_INTERVAL_MS=10000

# 本地状态文件
STATE_FILE=./data/state.json

# 服务配置
API_HOST=0.0.0.0
API_PORT=4210
API_AUTH_TOKEN=
CORS_ORIGIN=
