NODE_ENV=development

# 42space 官方 REST 接口
FORTYTWO_REST_BASE=https://rest.ft.42.space

# BNB 链接口。默认先用免费公共节点，小额跑通后再换自己的 RPC。
BSC_HTTP_RPC=https://bsc-dataseed.binance.org
BSC_WS_RPC=

# 可选。协议核验时用于检查 BscScan 交易和状态。
BSCSCAN_API_KEY=

# 钱包配置。WALLET_ADDRESS 可不填，程序会从 PRIVATE_KEY 自动推导。
WALLET_ADDRESS=
PRIVATE_KEY=

# 交易默认关闭，必须显式开启。
LIVE_TRADING=false
MAX_TRADE_USDT=3
DAILY_MAX_USDT=10
MAX_OPEN_POSITIONS=1
MAX_SLIPPAGE_BPS=500
MAX_GAS_GWEI=5
KILL_SWITCH=true
LIVE_TRADING_CONFIRMATION=I_UNDERSTAND_42BOT_LIVE_RISK
INTEGRATOR_ADDRESS=
INTEGRATOR_FEE_BPS=0
PROTOCOL_REPORT_JSON_PATH=./data/protocol-verification-latest.json
SETTINGS_FILE=./data/settings.json
RUNTIME_LOG_FILE=./data/runtime-log.json
JOURNAL_FILE=./data/journal.json

# 策略和风控默认值
REQUIRE_REAL_MINTS=true
HOT_MARKET_MIN_SCORE=70
MARKET_LOOKBACK_LIMIT=50
POLL_INTERVAL_MS=10000

# 本地状态文件
STATE_FILE=./data/state.json

# 服务配置
API_HOST=0.0.0.0
API_PORT=4210
API_AUTH_TOKEN=
CORS_ORIGIN=
